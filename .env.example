# Database (used by backend and docker-compose)
POSTGRES_DB=volleyball_marketing
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend

# CORS (comma-separated origins for the Vue app)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost,http://frontend

# Optional: external API base URL for campaigns service
# EXTERNAL_API_BASE_URL=
